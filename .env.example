# ── EasyNote configuration ──────────────────────────────────────────
# Copy this file to .env.local and fill in what you have.
# The app runs without any keys (transcripts, recording, demo note),
# but AI features need at least ANTHROPIC_API_KEY.

# ── AI provider ─────────────────────────────────────────────────────
# Option A: Anthropic Claude (default). Best quality; only provider that
# reads scanned PDFs natively. Get a key at https://platform.claude.com/
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8        # or claude-haiku-4-5 (cheaper)

# Option B: a cheaper OpenAI-compatible provider (DeepSeek, Zhipu GLM,
# Qwen/DashScope, Kimi, MiniMax, OpenAI, Groq…). Set these and the app
# switches automatically. Examples:
#   DeepSeek (text-only, no image OCR):
#     AI_PROVIDER=openai
#     AI_BASE_URL=https://api.deepseek.com
#     AI_API_KEY=sk-...
#     AI_MODEL=deepseek-v4-flash
#   Zhipu GLM (free text tier + vision, China-friendly):
#     AI_PROVIDER=openai
#     AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#     AI_API_KEY=...
#     AI_MODEL=glm-4.5-flash
#     AI_VISION_MODEL=glm-4.6v          # enables image OCR
#   Alibaba Qwen (China-hosted, vision):
#     AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#     AI_MODEL=qwen-plus   AI_VISION_MODEL=qwen3-vl-plus
# AI_PROVIDER=
# AI_BASE_URL=
# AI_API_KEY=
# AI_MODEL=
# AI_VISION_MODEL=

# Built-in models (each becomes selectable when its key is set):
# ZHIPU_API_KEY=          # GLM-4.5-Flash (FREE tier) + GLM-5.2 (+ vision)
# MINIMAX_API_KEY=        # MiniMax-M3 (multimodal)

# ── Plan-based model tiering ───────────────────────────────────────
# Which models require the Pro plan (comma-separated ids). Everything else
# is available to free users. Keep your paid models here so free users can't
# drain them. Default: "minimax-m3,glm-5.2"
# AI_PRO_MODELS=minimax-m3,glm-5.2
# Default model for FREE users (must be a free-tier model, e.g. the $0 GLM):
# AI_DEFAULT_MODEL=glm-4.5-flash
# Default model for PRO users:
# AI_PRO_DEFAULT_MODEL=minimax-m3

# Scanned PDFs (no text layer) are rasterized and OCR'd with the vision model.
# PDF_OCR_MAX_PAGES=15    # cap pages per scanned PDF (bounds cost/time)

# Optional — speech-to-text for UPLOADED audio/video files.
# Live in-browser recording works without this.
# Any OpenAI-compatible transcription endpoint is supported:
#   OpenAI:  set OPENAI_API_KEY (model whisper-1)
#   Groq:    STT_API_KEY=...  STT_BASE_URL=https://api.groq.com/openai/v1  STT_MODEL=whisper-large-v3
OPENAI_API_KEY=
# STT_API_KEY=
# STT_BASE_URL=https://api.openai.com/v1
# STT_MODEL=whisper-1

# Where user data (accounts, notes, uploads) is stored. Default: ./data
# DATA_DIR=./data
