# ── EasyNote configuration ──────────────────────────────────────────
# Copy this file to .env.local and fill in what you have.
# The app runs without any keys (transcripts, recording, demo note),
# but AI features need at least ANTHROPIC_API_KEY.

# Required for AI notes, summaries, flashcards, quizzes, chat,
# translation, image reading and scanned-PDF reading.
# Get one at https://platform.claude.com/
ANTHROPIC_API_KEY=

# Claude model to use (default: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional — speech-to-text for UPLOADED audio/video files.
# Live in-browser recording works without this.
# Any OpenAI-compatible transcription endpoint is supported:
#   OpenAI:  set OPENAI_API_KEY (model whisper-1)
#   Groq:    STT_API_KEY=...  STT_BASE_URL=https://api.groq.com/openai/v1  STT_MODEL=whisper-large-v3
OPENAI_API_KEY=
# STT_API_KEY=
# STT_BASE_URL=https://api.openai.com/v1
# STT_MODEL=whisper-1

# Where user data (accounts, notes, uploads) is stored. Default: ./data
# DATA_DIR=./data
